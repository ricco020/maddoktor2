---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../lib/site';
import { hreflangAlternates } from '../../../lib/hreflang';

const title = 'Vérificateur d’empreinte de fichier - SHA-256, SHA-1 et SHA-512 dans le navigateur';
const description =
  'Vérificateur d’empreinte de fichier gratuit. Calculez le SHA-256, SHA-1 et SHA-512 de n’importe quel fichier pour le rechercher dans les bases de malwares comme VirusTotal. Tout se passe dans votre navigateur - le fichier ne quitte jamais votre appareil.';

const alternates = hreflangAlternates('/file-hash-checker/');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Vérificateur d’empreinte de fichier',
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any (web browser)',
    description,
    url: `${SITE.url}/fr/file-hash-checker/`,
    inLanguage: 'fr',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': `${SITE.url}/#org` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Vérificateur d’empreinte de fichier', item: `${SITE.url}/fr/file-hash-checker/` },
    ],
  },
];
---

<Base {title} {description} {schema} lang="fr" {alternates} canonicalPath="/fr/file-hash-checker/">
  <article class="prose rise mx-auto">
    <p class="mono text-xs text-ink-faint">~ / file-hash-checker</p>
    <h1 class="mt-4 font-mono text-2xl font-semibold text-ink sm:text-3xl">Vérificateur d’empreinte de fichier</h1>

    <p class="mt-6 text-lg text-ink-dim">Calculez le <strong>SHA-256, SHA-1 et SHA-512</strong> de n’importe quel fichier, puis collez l’empreinte dans une base de malwares comme VirusTotal pour voir si le fichier est connu comme malveillant. Tout s’exécute <strong>dans votre navigateur</strong> grâce à l’API Web Crypto intégrée - le fichier ne quitte jamais votre appareil et rien n’est envoyé.</p>

    <div
      id="hashtool"
      class="hashtool"
      data-computing='Calcul des empreintes…'
      data-done='Terminé - copiez une empreinte ci-dessous'
      data-error='Impossible de lire ce fichier. Essayez-en un autre.'
      data-copy='Copier'
      data-copied='Copié'
      data-nofile='Choisissez un fichier pour commencer'
    >
      <label class="drop" id="drop" for="fileinput">
        <input type="file" id="fileinput" hidden />
        <span class="drop-icon" aria-hidden="true">🧮</span>
        <span class="drop-main">Déposez un fichier ici ou cliquez pour choisir</span>
        <span class="drop-sub" id="fileinfo">Choisissez un fichier pour commencer</span>
      </label>

      <p class="status" id="status" role="status" aria-live="polite"></p>

      <div class="rows" id="rows" hidden>
        <div class="hrow"><span class="halg">SHA-256</span><code class="hval" id="sha256"></code><button type="button" class="copy" data-target="sha256">Copier</button></div>
        <div class="hrow"><span class="halg">SHA-1</span><code class="hval" id="sha1"></code><button type="button" class="copy" data-target="sha1">Copier</button></div>
        <div class="hrow"><span class="halg">SHA-512</span><code class="hval" id="sha512"></code><button type="button" class="copy" data-target="sha512">Copier</button></div>
      </div>
    </div>

    <h2>Comment vérifier un fichier suspect</h2>
    <ol>
      <li>Sélectionnez le fichier ci-dessus. Ses empreintes apparaissent aussitôt.</li>
      <li>Copiez la valeur <strong>SHA-256</strong>.</li>
      <li>Collez-la dans un service de réputation - par exemple le champ de recherche de <a href="https://www.virustotal.com/" rel="nofollow noopener" target="_blank">VirusTotal</a>. Si le fichier est un malware connu, la base reconnaît l’empreinte.</li>
    </ol>

    <h2>Pourquoi une empreinte aide</h2>
    <p>Une empreinte est une courte signature d’un fichier. Changez un seul octet et l’empreinte change entièrement. Les bases de menaces stockent les empreintes des malwares connus : vérifier une empreinte vous dit si un fichier correspond à un échantillon déjà analysé - sans envoyer votre fichier où que ce soit.</p>

    <h2>Les limites honnêtes</h2>
    <p>Une recherche d’empreinte ne reconnaît que les échantillons <em>connus</em>. Un malware tout neuf ou légèrement modifié aura une empreinte que personne n’a encore vue : un résultat propre n’est <strong>pas</strong> une garantie que le fichier est sûr. Utilisez cet outil comme un signal parmi d’autres, en complément d’un vrai scan anti-malware. Nous n’offrons pas le MD5 ici : il est cryptographiquement cassé, et le SHA-256 est la valeur que préfèrent les bases modernes.</p>
  </article>
</Base>

<style>
  .hashtool { margin: 28px 0; }
  .drop {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; text-align: center; padding: 34px 18px; cursor: pointer;
    border: 2px dashed var(--line, #3a3a44); border-radius: 14px;
    background: rgba(255,255,255,0.02); transition: border-color .15s, background .15s;
  }
  .drop:hover, .drop.over { border-color: #22c55e; background: rgba(34,197,94,0.06); }
  .drop-icon { font-size: 30px; }
  .drop-main { font-weight: 600; }
  .drop-sub { font-size: 13px; opacity: .7; word-break: break-all; }
  .status { min-height: 20px; font-size: 14px; opacity: .85; margin: 12px 2px; }
  .rows { display: flex; flex-direction: column; gap: 10px; }
  .hrow {
    display: grid; grid-template-columns: 84px 1fr auto; align-items: center; gap: 10px;
    padding: 10px 12px; border: 1px solid var(--line, #33333c); border-radius: 10px;
    background: rgba(255,255,255,0.02);
  }
  .halg { font-family: ui-monospace, monospace; font-size: 12px; font-weight: 700; color: #22c55e; }
  .hval { font-family: ui-monospace, monospace; font-size: 12.5px; word-break: break-all; }
  .copy {
    font-size: 12px; padding: 5px 12px; border-radius: 8px; cursor: pointer;
    border: 1px solid var(--line, #3a3a44); background: transparent; color: inherit;
  }
  .copy:hover { border-color: #22c55e; color: #22c55e; }
  @media (max-width: 560px) { .hrow { grid-template-columns: 1fr; } }
</style>

<script>
  const el = document.getElementById('hashtool');
  if (el) {
    const d = el.dataset;
    const input = document.getElementById('fileinput');
    const drop = document.getElementById('drop');
    const status = document.getElementById('status');
    const rows = document.getElementById('rows');
    const info = document.getElementById('fileinfo');
    const algos = { 'SHA-256': 'sha256', 'SHA-1': 'sha1', 'SHA-512': 'sha512' };

    const toHex = (buf) =>
      Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, '0')).join('');

    const fmtSize = (n) => {
      if (n < 1024) return n + ' B';
      if (n < 1048576) return (n / 1024).toFixed(1) + ' KB';
      if (n < 1073741824) return (n / 1048576).toFixed(1) + ' MB';
      return (n / 1073741824).toFixed(2) + ' GB';
    };

    async function run(file) {
      if (!file) return;
      info.textContent = file.name + ' (' + fmtSize(file.size) + ')';
      status.textContent = d.computing;
      rows.hidden = true;
      try {
        const buf = await file.arrayBuffer();
        for (const [alg, id] of Object.entries(algos)) {
          const digest = await crypto.subtle.digest(alg, buf);
          document.getElementById(id).textContent = toHex(digest);
        }
        rows.hidden = false;
        status.textContent = d.done;
      } catch (e) {
        status.textContent = d.error;
      }
    }

    input.addEventListener('change', () => run(input.files[0]));
    ['dragenter', 'dragover'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); })
    );
    ['dragleave', 'drop'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); })
    );
    drop.addEventListener('drop', (e) => {
      const f = e.dataTransfer && e.dataTransfer.files[0];
      if (f) run(f);
    });

    document.querySelectorAll('.copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const val = document.getElementById(btn.dataset.target).textContent;
        if (!val) return;
        try {
          await navigator.clipboard.writeText(val);
          const old = btn.textContent;
          btn.textContent = d.copied;
          setTimeout(() => { btn.textContent = old; }, 1200);
        } catch (e) {}
      });
    });
  }
</script>
