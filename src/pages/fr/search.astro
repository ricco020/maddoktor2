---
import Base from '../../layouts/Base.astro';
import { ui } from '../../lib/ui';
import { hreflangAlternates } from '../../lib/hreflang';
import { getCollection } from 'astro:content';

const lang = 'fr';
const t = ui[lang];
const articles = (await getCollection('articlesFr')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('fr-FR', { month: 'short', day: 'numeric', year: 'numeric' });
const AV: Record<string,{color:string;svg:string}> = {
  os:     { color:'#0f766e', svg:'<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>' },
  tor:    { color:'#7b3fb5', svg:'<circle cx="12" cy="12" r="8"/><path d="M12 4v16M4 12h16M6 6l12 12M18 6L6 18"/>' },
  enc:    { color:'#c2680f', svg:'<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>' },
  phone:  { color:'#1d6fe0', svg:'<rect x="7" y="3" width="10" height="18" rx="2"/><line x1="11" y1="18" x2="13" y2="18"/>' },
  msg:    { color:'#0e9e90', svg:'<path d="M4 5h16v11H8l-4 4z"/>' },
  linux:  { color:'#3a7d3a', svg:'<polyline points="5 8 9 12 5 16"/><line x1="12" y1="16" x2="19" y2="16"/>' },
  browser:{ color:'#2563eb', svg:'<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"/>' },
  shield: { color:'#0c7d72', svg:'<path d="M12 3l7 3v5c0 4-3 7-7 9-4-2-7-5-7-9V6z"/><polyline points="9 12 11 14 15 9.5"/>' },
};
function tagAvatar(tags: string[] = []) {
  const tg = tags.join(' ').toLowerCase();
  if (/(ransomware|extortion|decrypt)/.test(tg)) return AV.enc;
  if (/(spyware|adware|keylogger|stalkerware|tracking)/.test(tg)) return AV.browser;
  if (/(antivirus|scanner|tool|defender)/.test(tg)) return AV.os;
  if (/(phishing|scam|email)/.test(tg)) return AV.msg;
  if (/(android|ios|mobile|phone)/.test(tg)) return AV.phone;
  if (/(windows|firewall|harden|update|account)/.test(tg)) return AV.linux;
  return AV.shield;
}
const alternates = hreflangAlternates('/search/');
---
<Base title="Rechercher dans les guides — MadDoktor2" description="Recherchez dans tous les guides MadDoktor2 sur la suppression de malwares, l'anti-spyware et la sécurité PC." lang={lang} alternates={alternates} canonicalPath="/fr/search/">
  <div class="wrap">
    <div class="cathead">
      <p class="k">{t.search_k}</p>
      <h1>{t.search_h1}</h1>
      <form class="searchpage" role="search" onsubmit="return false">
        <input id="q" type="search" placeholder={t.search_ph2} aria-label={t.search_h1} autocomplete="off" autofocus />
      </form>
      <p class="count"><b id="cn">{articles.length}</b> <span class="lbl" id="cl" data-singular="guide">guides</span></p>
    </div>
    <div class="layout" style="grid-template-columns:1fr">
      <div class="main" id="results">
        {articles.map((a) => (
          <article class="story" data-search={`${a.data.title} ${a.data.description} ${a.data.tags.join(' ')}`.toLowerCase()}>
            <span class="ava cat-ava" style={`background:${tagAvatar(a.data.tags).color}`} aria-hidden="true"><svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tagAvatar(a.data.tags).svg} /></span>
            <div>
              <p class="by"><a href="/fr/about/">MadDoktor2</a> <em>{t.wrote}</em></p>
              <h3><a href={`/fr/articles/${a.id}/`}>{a.data.title}</a></h3>
              <p class="ex"><span class="date">{fmt(a.data.pubDate)}</span> · {a.data.tags.slice(0,3).join(', ')} — {a.data.description}</p>
              <a class="more" href={`/fr/articles/${a.id}/`}>{t.read_more}</a>
            </div>
          </article>
        ))}
        <p id="noresult" class="ex" style="display:none">{t.no_result} <a href="/fr/articles/">{t.browse_all}</a></p>
      </div>
    </div>
  </div>
  <script>
    (function(){
      var q = document.getElementById('q');
      var items = Array.prototype.slice.call(document.querySelectorAll('#results .story'));
      var cn = document.getElementById('cn'), cl = document.getElementById('cl');
      var none = document.getElementById('noresult');
      var wordSingular = (cl && cl.getAttribute('data-singular')) || 'guide';
      var wordPlural = (cl && cl.textContent) || 'guides';
      function apply(term){
        term = (term||'').trim().toLowerCase();
        var n = 0;
        items.forEach(function(el){
          var hit = !term || el.getAttribute('data-search').indexOf(term) !== -1;
          el.style.display = hit ? '' : 'none';
          if (hit) n++;
        });
        cn.textContent = String(n);
        cl.textContent = (n === 1 ? wordSingular : wordPlural);
        none.style.display = n ? 'none' : '';
      }
      var params = new URLSearchParams(location.search);
      var initial = params.get('q') || '';
      if (initial) { q.value = initial; apply(initial); }
      q.addEventListener('input', function(){ apply(q.value); });
    })();
  </script>
</Base>
