---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../lib/site';
import { hreflangAlternates } from '../../../lib/hreflang';

const title = "Verificador de URL - Detecta senales de phishing en un enlace";
const description = "Verificador de URL gratuito. Pega un enlace sospechoso y la herramienta inspecciona la direccion en busca de senales de phishing comunes, todo en tu navegador. No garantiza que un sitio sea seguro, solo marca advertencias.";

const alternates = hreflangAlternates('/url-safety-checker/');

const MSG = {"empty": "Pega un enlace para comprobarlo.", "invalid": "Eso no parece una URL valida.", "verdictClean": "Sin senales comunes en la direccion. Aun asi no es garantia de seguridad.", "verdictInfo": "Algunos detalles a tener en cuenta en este enlace.", "verdictWarn": "Algunas senales de advertencia - ten cuidado con este enlace.", "verdictBad": "Senales fuertes - trata este enlace como sospechoso.", "disclaimer": "Esta herramienta solo inspecciona el texto de la URL en busca de senales comunes. No puede confirmar si un sitio es seguro o malicioso. Ante la duda, no hagas clic.", "msg": {"notHttps": "Este enlace usa http, no https, asi que el trafico puede leerse o alterarse por el camino.", "ipHost": "La direccion es una IP en crudo, no un nombre de dominio - comun en phishing, raro en marcas reales.", "atSymbol": "La URL contiene '@'. Todo lo anterior lo ignora el navegador - un truco clasico para ocultar el destino real.", "punycode": "El dominio usa punycode (xn--) y puede mostrarse como imitacion de un nombre conocido.", "manySub": "El dominio tiene muchos subdominios. Un nombre de marca en un subdominio no lo convierte en esa marca.", "shortener": "Es un acortador de enlaces - el destino real queda oculto hasta que haces clic.", "riskyTld": "El dominio de nivel superior es de los que se abusan con frecuencia. No es prueba, pero cuidado.", "hyphens": "El dominio tiene varios guiones, a menudo usados para crear nombres imitados.", "port": "La URL usa un puerto no estandar, inusual en sitios normales.", "encodedHost": "El host contiene caracteres codificados en porcentaje, a veces usados para ocultar el dominio real.", "longUrl": "La URL es muy larga, lo que puede enterrar el dominio real fuera de la vista.", "brandLookalike": "Un nombre de marca conocida aparece en la direccion pero no como dominio principal - un patron de suplantacion comun.", "clean": "No se hallaron senales estructurales comunes. Esto no significa que el sitio sea seguro, solo que la direccion parece corriente."}};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: "Verificador de URL",
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any (web browser)',
    description,
    url: `${SITE.url}/es/url-safety-checker/`,
    inLanguage: 'es',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': `${SITE.url}/#org` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: "Inicio", item: SITE.url },
      { '@type': 'ListItem', position: 2, name: "Verificador de URL", item: `${SITE.url}/es/url-safety-checker/` },
    ],
  },
];
---

<Base {title} {description} {schema} lang="es" {alternates} canonicalPath="/es/url-safety-checker/">
  <article class="prose rise mx-auto">
    <p class="mono text-xs text-ink-faint">~ / url-safety-checker</p>
    <h1 class="mt-4 font-mono text-2xl font-semibold text-ink sm:text-3xl">Verificador de URL</h1>

    <p class="mt-6 text-lg text-ink-dim" set:html={"Pega un enlace sospechoso abajo. Esta herramienta inspecciona <strong>la propia direccion</strong> en busca de senales comunes de phishing y malware - IP en crudo, nombres de marca imitados, punycode, acortadores arriesgados y mas. Funciona <strong>por completo en tu navegador</strong>, nunca visita el enlace ni lo envia a ningun sitio."}></p>

    <div id="urltool" class="urltool">
      <div class="urlrow">
        <input id="urlinput" type="text" inputmode="url" autocomplete="off" spellcheck="false" placeholder="Pega una URL, p. ej. http://paypal.secure-login.example.tk/verify" />
        <button id="analyze" type="button">Comprobar el enlace</button>
      </div>
      <p id="verdict" class="verdict" role="status" aria-live="polite"></p>
      <div id="results"></div>
    </div>

    <h2>Que busca</h2>
    <p>Marca senales estructurales en la direccion: falta de HTTPS, una IP en lugar de un dominio, una @ que oculta el destino real, imitaciones en punycode, subdominios profundos, acortadores de enlaces, dominios de nivel superior a menudo abusados, puertos raros, caracteres codificados y nombres de marcas conocidas usados fuera del dominio principal.</p>

    <h2>Los limites honestos</h2>
    <p set:html={"Es una comprobacion de texto, no un veredicto. No puede abrir la pagina, ejecutar un analisis ni consultar una base de amenazas, asi que un resultado limpio <strong>no</strong> prueba que un sitio sea seguro, y una advertencia no prueba que sea malicioso. Toma las advertencias como motivo para ir despacio. Ante la duda, no hagas clic - escribe la direccion tu mismo o abre la app oficial."}></p>
    <p class="related-tool"><strong>Herramienta relacionada:</strong> <a href="/es/file-hash-checker/">Verificador de hash de archivo</a></p>
  </article>
</Base>

<style>
  .urltool { margin: 26px 0; }
  .urlrow { display: flex; gap: 8px; flex-wrap: wrap; }
  .urlrow input {
    flex: 1 1 260px; min-width: 0; padding: 12px 14px; font-family: ui-monospace, monospace;
    font-size: 14px; border-radius: 10px; border: 1px solid var(--line, #33333c);
    background: rgba(255,255,255,0.02); color: inherit;
  }
  .urlrow input:focus { outline: none; border-color: #22c55e; }
  .urlrow button {
    padding: 12px 20px; border-radius: 10px; border: 1px solid #22c55e; cursor: pointer;
    background: rgba(34,197,94,0.12); color: #22c55e; font-weight: 600;
  }
  .urlrow button:hover { background: rgba(34,197,94,0.2); }
  .verdict { margin: 18px 2px 8px; font-weight: 700; min-height: 22px; }
  .v-clean { color: #22c55e; } .v-info { color: #38bdf8; } .v-warn { color: #f59e0b; } .v-bad { color: #ef4444; }
  .findings { list-style: none; padding: 0; margin: 8px 0; display: flex; flex-direction: column; gap: 8px; }
  .findings li {
    padding: 10px 12px 10px 14px; border-radius: 10px; font-size: 14px; line-height: 1.45;
    border: 1px solid var(--line, #33333c); border-left-width: 4px; background: rgba(255,255,255,0.02);
  }
  .f-bad { border-left-color: #ef4444; } .f-warn { border-left-color: #f59e0b; }
  .f-info { border-left-color: #38bdf8; } .f-clean { border-left-color: #22c55e; }
  .disclaimer { font-size: 12.5px; opacity: .7; margin-top: 14px; }
</style>


<script is:inline define:vars={{ MSG: MSG }}>
  const el = document.getElementById('urltool');
  if (el) {
    const input = document.getElementById('urlinput');
    const btn = document.getElementById('analyze');
    const out = document.getElementById('results');
    const verdict = document.getElementById('verdict');
    const SHORTENERS = ['bit.ly','tinyurl.com','goo.gl','t.co','ow.ly','is.gd','buff.ly','rebrand.ly','cutt.ly','t.ly','rb.gy','shorturl.at'];
    const RISKY_TLDS = ['zip','mov','tk','gq','ml','cf','ga','top','xyz','click','country','kim','work','loan','support','rest'];
    const BRANDS = ['paypal','apple','icloud','microsoft','office365','amazon','netflix','google','facebook','instagram','whatsapp','bank','coinbase','binance','metamask','dhl','fedex','ups','usps'];

    function analyze(raw) {
      const findings = [];
      let value = (raw || '').trim();
      if (!value) return null;
      if (!/^[a-z][a-z0-9+.-]*:\/\//i.test(value)) value = 'http://' + value;
      let u;
      try { u = new URL(value); } catch (e) { return { error: true }; }
      const host = u.hostname.toLowerCase();
      const labels = host.split('.');
      const tld = labels[labels.length - 1] || '';
      const registrable = labels.slice(-2).join('.');

      if (u.protocol === 'http:') findings.push({ s: 'warn', k: 'notHttps' });
      if (/^\d{1,3}(\.\d{1,3}){3}$/.test(host)) findings.push({ s: 'bad', k: 'ipHost' });
      if (u.username || u.password || raw.split('#')[0].split('?')[0].includes('@')) findings.push({ s: 'bad', k: 'atSymbol' });
      if (host.includes('xn--')) findings.push({ s: 'bad', k: 'punycode' });
      if (labels.length > 4) findings.push({ s: 'warn', k: 'manySub' });
      if (SHORTENERS.includes(registrable)) findings.push({ s: 'warn', k: 'shortener' });
      if (RISKY_TLDS.includes(tld)) findings.push({ s: 'warn', k: 'riskyTld' });
      if ((registrable.match(/-/g) || []).length >= 2) findings.push({ s: 'warn', k: 'hyphens' });
      if (u.port) findings.push({ s: 'warn', k: 'port' });
      if (host.includes('%')) findings.push({ s: 'bad', k: 'encodedHost' });
      if (value.length > 100) findings.push({ s: 'info', k: 'longUrl' });
      const brandHit = BRANDS.find((b) => host.includes(b));
      if (brandHit && registrable.indexOf(brandHit) !== 0) findings.push({ s: 'bad', k: 'brandLookalike' });
      return { host, findings };
    }

    function render(raw) {
      out.replaceChildren();
      verdict.textContent = '';
      verdict.className = 'verdict';
      const res = analyze(raw);
      if (!res) { verdict.textContent = MSG.empty; return; }
      if (res.error) { verdict.textContent = MSG.invalid; verdict.classList.add('v-bad'); return; }
      const findings = res.findings;
      const worst = findings.some((f) => f.s === 'bad') ? 'bad' : findings.some((f) => f.s === 'warn') ? 'warn' : findings.length ? 'info' : 'clean';
      verdict.classList.add('v-' + worst);
      verdict.textContent = worst === 'clean' ? MSG.verdictClean
        : worst === 'bad' ? MSG.verdictBad
        : worst === 'warn' ? MSG.verdictWarn : MSG.verdictInfo;

      const list = document.createElement('ul');
      list.className = 'findings';
      if (!findings.length) {
        const li = document.createElement('li');
        li.className = 'f-clean';
        li.textContent = MSG.msg.clean;
        list.appendChild(li);
      } else {
        findings.forEach((f) => {
          const li = document.createElement('li');
          li.className = 'f-' + f.s;
          li.textContent = MSG.msg[f.k];
          list.appendChild(li);
        });
      }
      out.appendChild(list);
      const note = document.createElement('p');
      note.className = 'disclaimer';
      note.textContent = MSG.disclaimer;
      out.appendChild(note);
    }

    btn.addEventListener('click', () => render(input.value));
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') render(input.value); });
  }
</script>
