---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../lib/site';
import { hreflangAlternates } from '../../../lib/hreflang';

const title = 'Verificador de hash de archivos - SHA-256, SHA-1 y SHA-512 en el navegador';
const description =
  'Verificador de hash de archivos gratuito. Calcula el SHA-256, SHA-1 y SHA-512 de cualquier archivo para buscarlo en bases de datos de malware como VirusTotal. Todo ocurre en tu navegador - el archivo nunca sale de tu dispositivo.';

const alternates = hreflangAlternates('/file-hash-checker/');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Verificador de hash de archivos',
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any (web browser)',
    description,
    url: `${SITE.url}/es/file-hash-checker/`,
    inLanguage: 'es',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': `${SITE.url}/#org` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Verificador de hash de archivos', item: `${SITE.url}/es/file-hash-checker/` },
    ],
  },
];
---

<Base {title} {description} {schema} lang="es" {alternates} canonicalPath="/es/file-hash-checker/">
  <article class="prose rise mx-auto">
    <p class="mono text-xs text-ink-faint">~ / file-hash-checker</p>
    <h1 class="mt-4 font-mono text-2xl font-semibold text-ink sm:text-3xl">Verificador de hash de archivos</h1>

    <p class="mt-6 text-lg text-ink-dim">Calcula el <strong>SHA-256, SHA-1 y SHA-512</strong> de cualquier archivo y luego pega el hash en una base de datos de malware como VirusTotal para ver si el archivo es conocido como malicioso. Todo se ejecuta <strong>en tu navegador</strong> con la API Web Crypto integrada - el archivo nunca sale de tu dispositivo y no se sube nada.</p>

    <div
      id="hashtool"
      class="hashtool"
      data-computing='Calculando hashes…'
      data-done='Listo - copia un hash abajo'
      data-error='No se pudo leer el archivo. Prueba con otro.'
      data-copy='Copiar'
      data-copied='Copiado'
      data-nofile='Elige un archivo para empezar'
    >
      <label class="drop" id="drop" for="fileinput">
        <input type="file" id="fileinput" hidden />
        <span class="drop-icon" aria-hidden="true">🧮</span>
        <span class="drop-main">Suelta un archivo aquí o haz clic para elegir</span>
        <span class="drop-sub" id="fileinfo">Elige un archivo para empezar</span>
      </label>

      <p class="status" id="status" role="status" aria-live="polite"></p>

      <div class="rows" id="rows" hidden>
        <div class="hrow"><span class="halg">SHA-256</span><code class="hval" id="sha256"></code><button type="button" class="copy" data-target="sha256">Copiar</button></div>
        <div class="hrow"><span class="halg">SHA-1</span><code class="hval" id="sha1"></code><button type="button" class="copy" data-target="sha1">Copiar</button></div>
        <div class="hrow"><span class="halg">SHA-512</span><code class="hval" id="sha512"></code><button type="button" class="copy" data-target="sha512">Copiar</button></div>
      </div>
    </div>

    <h2>Cómo comprobar un archivo sospechoso</h2>
    <ol>
      <li>Selecciona el archivo de arriba. Sus hashes aparecen al instante.</li>
      <li>Copia el valor <strong>SHA-256</strong>.</li>
      <li>Pégalo en un servicio de reputación - por ejemplo el buscador de <a href="https://www.virustotal.com/" rel="nofollow noopener" target="_blank">VirusTotal</a>. Si el archivo es malware conocido, la base de datos reconoce el hash.</li>
    </ol>

    <h2>Por qué ayuda un hash</h2>
    <p>Un hash es una huella corta de un archivo. Cambia un solo byte y el hash cambia por completo. Las bases de amenazas guardan los hashes del malware conocido, así que comprobar un hash te dice si un archivo coincide con una muestra ya analizada - sin subir tu archivo a ningún sitio.</p>

    <h2>Los límites honestos</h2>
    <p>Una búsqueda de hash solo reconoce muestras <em>conocidas</em>. Un malware nuevo o ligeramente alterado tendrá un hash que nadie ha visto todavía: un resultado limpio <strong>no</strong> garantiza que el archivo sea seguro. Úsalo como una señal más, junto a un análisis antimalware real. No ofrecemos MD5 aquí: está roto criptográficamente, y el SHA-256 es el valor que prefieren las bases modernas.</p>
    <p class="related-tool"><strong>Herramienta relacionada:</strong> <a href="/es/url-safety-checker/">Verificador de URL</a></p>
  </article>
</Base>

<style>
  .hashtool { margin: 28px 0; }
  .drop {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; text-align: center; padding: 34px 18px; cursor: pointer;
    border: 2px dashed var(--line, #3a3a44); border-radius: 14px;
    background: rgba(255,255,255,0.02); transition: border-color .15s, background .15s;
  }
  .drop:hover, .drop.over { border-color: #22c55e; background: rgba(34,197,94,0.06); }
  .drop-icon { font-size: 30px; }
  .drop-main { font-weight: 600; }
  .drop-sub { font-size: 13px; opacity: .7; word-break: break-all; }
  .status { min-height: 20px; font-size: 14px; opacity: .85; margin: 12px 2px; }
  .rows { display: flex; flex-direction: column; gap: 10px; }
  .hrow {
    display: grid; grid-template-columns: 84px 1fr auto; align-items: center; gap: 10px;
    padding: 10px 12px; border: 1px solid var(--line, #33333c); border-radius: 10px;
    background: rgba(255,255,255,0.02);
  }
  .halg { font-family: ui-monospace, monospace; font-size: 12px; font-weight: 700; color: #22c55e; }
  .hval { font-family: ui-monospace, monospace; font-size: 12.5px; word-break: break-all; }
  .copy {
    font-size: 12px; padding: 5px 12px; border-radius: 8px; cursor: pointer;
    border: 1px solid var(--line, #3a3a44); background: transparent; color: inherit;
  }
  .copy:hover { border-color: #22c55e; color: #22c55e; }
  @media (max-width: 560px) { .hrow { grid-template-columns: 1fr; } }
</style>

<script>
  const el = document.getElementById('hashtool');
  if (el) {
    const d = el.dataset;
    const input = document.getElementById('fileinput');
    const drop = document.getElementById('drop');
    const status = document.getElementById('status');
    const rows = document.getElementById('rows');
    const info = document.getElementById('fileinfo');
    const algos = { 'SHA-256': 'sha256', 'SHA-1': 'sha1', 'SHA-512': 'sha512' };

    const toHex = (buf) =>
      Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, '0')).join('');

    const fmtSize = (n) => {
      if (n < 1024) return n + ' B';
      if (n < 1048576) return (n / 1024).toFixed(1) + ' KB';
      if (n < 1073741824) return (n / 1048576).toFixed(1) + ' MB';
      return (n / 1073741824).toFixed(2) + ' GB';
    };

    async function run(file) {
      if (!file) return;
      info.textContent = file.name + ' (' + fmtSize(file.size) + ')';
      status.textContent = d.computing;
      rows.hidden = true;
      try {
        const buf = await file.arrayBuffer();
        for (const [alg, id] of Object.entries(algos)) {
          const digest = await crypto.subtle.digest(alg, buf);
          document.getElementById(id).textContent = toHex(digest);
        }
        rows.hidden = false;
        status.textContent = d.done;
      } catch (e) {
        status.textContent = d.error;
      }
    }

    input.addEventListener('change', () => run(input.files[0]));
    ['dragenter', 'dragover'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); })
    );
    ['dragleave', 'drop'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); })
    );
    drop.addEventListener('drop', (e) => {
      const f = e.dataTransfer && e.dataTransfer.files[0];
      if (f) run(f);
    });

    document.querySelectorAll('.copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const val = document.getElementById(btn.dataset.target).textContent;
        if (!val) return;
        try {
          await navigator.clipboard.writeText(val);
          const old = btn.textContent;
          btn.textContent = d.copied;
          setTimeout(() => { btn.textContent = old; }, 1200);
        } catch (e) {}
      });
    });
  }
</script>
