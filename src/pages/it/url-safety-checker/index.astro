---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../lib/site';
import { hreflangAlternates } from '../../../lib/hreflang';

const title = "Verificatore di URL - Individua i segnali di phishing in un link";
const description = "Verificatore di URL gratuito. Incolla un link sospetto e lo strumento ispeziona l'indirizzo alla ricerca di segnali di phishing comuni, tutto nel browser. Non garantisce che un sito sia sicuro, segnala solo avvisi.";

const alternates = hreflangAlternates('/url-safety-checker/');

const MSG = {"empty": "Incolla un link per controllarlo.", "invalid": "Non sembra una URL valida.", "verdictClean": "Nessun segnale comune nell'indirizzo. Comunque non e una garanzia di sicurezza.", "verdictInfo": "Alcuni dettagli da notare in questo link.", "verdictWarn": "Alcuni segnali di avviso - fai attenzione a questo link.", "verdictBad": "Forti segnali - tratta questo link come sospetto.", "disclaimer": "Questo strumento ispeziona solo il testo della URL alla ricerca di segnali comuni. Non puo confermare se un sito e sicuro o dannoso. Nel dubbio, non cliccare.", "msg": {"notHttps": "Questo link usa http, non https, quindi il traffico puo essere letto o alterato lungo il percorso.", "ipHost": "L'indirizzo e un IP grezzo, non un nome di dominio - comune nel phishing, raro per i marchi veri.", "atSymbol": "La URL contiene '@'. Tutto cio che precede viene ignorato dal browser - un classico trucco per nascondere la vera destinazione.", "punycode": "Il dominio usa il punycode (xn--) e puo apparire come imitazione di un nome noto.", "manySub": "Il dominio ha molti sottodomini. Un nome di marca in un sottodominio non lo rende quel marchio.", "shortener": "E un accorciatore di link - la vera destinazione e nascosta fino al clic.", "riskyTld": "Il dominio di primo livello e tra quelli spesso abusati. Non e una prova, ma attenzione.", "hyphens": "Il dominio ha piu trattini, spesso usati per creare nomi imitati.", "port": "La URL usa una porta non standard, insolita per i siti normali.", "encodedHost": "L'host contiene caratteri codificati in percentuale, a volte usati per offuscare il vero dominio.", "longUrl": "La URL e molto lunga, il che puo nascondere il vero dominio alla vista.", "brandLookalike": "Un nome di marca noto compare nell'indirizzo ma non come dominio principale - uno schema di impersonificazione comune.", "clean": "Nessun segnale strutturale comune trovato. Questo non significa che il sito sia sicuro, solo che l'indirizzo sembra ordinario."}};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: "Verificatore di URL",
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any (web browser)',
    description,
    url: `${SITE.url}/it/url-safety-checker/`,
    inLanguage: 'it',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': `${SITE.url}/#org` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: "Home", item: SITE.url },
      { '@type': 'ListItem', position: 2, name: "Verificatore di URL", item: `${SITE.url}/it/url-safety-checker/` },
    ],
  },
];
---

<Base {title} {description} {schema} lang="it" {alternates} canonicalPath="/it/url-safety-checker/">
  <article class="prose rise mx-auto">
    <p class="mono text-xs text-ink-faint">~ / url-safety-checker</p>
    <h1 class="mt-4 font-mono text-2xl font-semibold text-ink sm:text-3xl">Verificatore di URL</h1>

    <p class="mt-6 text-lg text-ink-dim" set:html={"Incolla un link sospetto qui sotto. Questo strumento ispeziona <strong>l'indirizzo stesso</strong> alla ricerca di segnali comuni di phishing e malware - IP grezzi, nomi di marca imitati, punycode, accorciatori rischiosi e altro. Funziona <strong>interamente nel tuo browser</strong>, non visita mai il link e non lo invia da nessuna parte."}></p>

    <div id="urltool" class="urltool">
      <div class="urlrow">
        <input id="urlinput" type="text" inputmode="url" autocomplete="off" spellcheck="false" placeholder="Incolla una URL, es. http://paypal.secure-login.example.tk/verify" />
        <button id="analyze" type="button">Controlla il link</button>
      </div>
      <p id="verdict" class="verdict" role="status" aria-live="polite"></p>
      <div id="results"></div>
    </div>

    <h2>Cosa cerca</h2>
    <p>Segnala indizi strutturali nell'indirizzo: assenza di HTTPS, un IP invece di un dominio, una @ che nasconde la vera destinazione, imitazioni in punycode, sottodomini profondi, accorciatori di link, domini di primo livello spesso abusati, porte insolite, caratteri codificati e nomi di marchi noti usati fuori dal dominio principale.</p>

    <h2>I limiti onesti</h2>
    <p set:html={"E un controllo del testo, non un verdetto. Non puo aprire la pagina, eseguire una scansione o interrogare un database di minacce, quindi un risultato pulito <strong>non</strong> prova che un sito sia sicuro, e un avviso non prova che sia dannoso. Considera gli avvisi come un motivo per rallentare. Nel dubbio, non cliccare - digita tu l'indirizzo o apri l'app ufficiale."}></p>
    <p class="related-tool"><strong>Strumento correlato:</strong> <a href="/it/file-hash-checker/">Verificatore di hash file</a></p>
  </article>
</Base>

<style>
  .urltool { margin: 26px 0; }
  .urlrow { display: flex; gap: 8px; flex-wrap: wrap; }
  .urlrow input {
    flex: 1 1 260px; min-width: 0; padding: 12px 14px; font-family: ui-monospace, monospace;
    font-size: 14px; border-radius: 10px; border: 1px solid var(--line, #33333c);
    background: rgba(255,255,255,0.02); color: inherit;
  }
  .urlrow input:focus { outline: none; border-color: #22c55e; }
  .urlrow button {
    padding: 12px 20px; border-radius: 10px; border: 1px solid #22c55e; cursor: pointer;
    background: rgba(34,197,94,0.12); color: #22c55e; font-weight: 600;
  }
  .urlrow button:hover { background: rgba(34,197,94,0.2); }
  .verdict { margin: 18px 2px 8px; font-weight: 700; min-height: 22px; }
  .v-clean { color: #22c55e; } .v-info { color: #38bdf8; } .v-warn { color: #f59e0b; } .v-bad { color: #ef4444; }
  .findings { list-style: none; padding: 0; margin: 8px 0; display: flex; flex-direction: column; gap: 8px; }
  .findings li {
    padding: 10px 12px 10px 14px; border-radius: 10px; font-size: 14px; line-height: 1.45;
    border: 1px solid var(--line, #33333c); border-left-width: 4px; background: rgba(255,255,255,0.02);
  }
  .f-bad { border-left-color: #ef4444; } .f-warn { border-left-color: #f59e0b; }
  .f-info { border-left-color: #38bdf8; } .f-clean { border-left-color: #22c55e; }
  .disclaimer { font-size: 12.5px; opacity: .7; margin-top: 14px; }
</style>


<script is:inline define:vars={{ MSG: MSG }}>
  const el = document.getElementById('urltool');
  if (el) {
    const input = document.getElementById('urlinput');
    const btn = document.getElementById('analyze');
    const out = document.getElementById('results');
    const verdict = document.getElementById('verdict');
    const SHORTENERS = ['bit.ly','tinyurl.com','goo.gl','t.co','ow.ly','is.gd','buff.ly','rebrand.ly','cutt.ly','t.ly','rb.gy','shorturl.at'];
    const RISKY_TLDS = ['zip','mov','tk','gq','ml','cf','ga','top','xyz','click','country','kim','work','loan','support','rest'];
    const BRANDS = ['paypal','apple','icloud','microsoft','office365','amazon','netflix','google','facebook','instagram','whatsapp','bank','coinbase','binance','metamask','dhl','fedex','ups','usps'];

    function analyze(raw) {
      const findings = [];
      let value = (raw || '').trim();
      if (!value) return null;
      if (!/^[a-z][a-z0-9+.-]*:\/\//i.test(value)) value = 'http://' + value;
      let u;
      try { u = new URL(value); } catch (e) { return { error: true }; }
      const host = u.hostname.toLowerCase();
      const labels = host.split('.');
      const tld = labels[labels.length - 1] || '';
      const registrable = labels.slice(-2).join('.');

      if (u.protocol === 'http:') findings.push({ s: 'warn', k: 'notHttps' });
      if (/^\d{1,3}(\.\d{1,3}){3}$/.test(host)) findings.push({ s: 'bad', k: 'ipHost' });
      if (u.username || u.password || raw.split('#')[0].split('?')[0].includes('@')) findings.push({ s: 'bad', k: 'atSymbol' });
      if (host.includes('xn--')) findings.push({ s: 'bad', k: 'punycode' });
      if (labels.length > 4) findings.push({ s: 'warn', k: 'manySub' });
      if (SHORTENERS.includes(registrable)) findings.push({ s: 'warn', k: 'shortener' });
      if (RISKY_TLDS.includes(tld)) findings.push({ s: 'warn', k: 'riskyTld' });
      if ((registrable.match(/-/g) || []).length >= 2) findings.push({ s: 'warn', k: 'hyphens' });
      if (u.port) findings.push({ s: 'warn', k: 'port' });
      if (host.includes('%')) findings.push({ s: 'bad', k: 'encodedHost' });
      if (value.length > 100) findings.push({ s: 'info', k: 'longUrl' });
      const brandHit = BRANDS.find((b) => host.includes(b));
      if (brandHit && registrable.indexOf(brandHit) !== 0) findings.push({ s: 'bad', k: 'brandLookalike' });
      return { host, findings };
    }

    function render(raw) {
      out.replaceChildren();
      verdict.textContent = '';
      verdict.className = 'verdict';
      const res = analyze(raw);
      if (!res) { verdict.textContent = MSG.empty; return; }
      if (res.error) { verdict.textContent = MSG.invalid; verdict.classList.add('v-bad'); return; }
      const findings = res.findings;
      const worst = findings.some((f) => f.s === 'bad') ? 'bad' : findings.some((f) => f.s === 'warn') ? 'warn' : findings.length ? 'info' : 'clean';
      verdict.classList.add('v-' + worst);
      verdict.textContent = worst === 'clean' ? MSG.verdictClean
        : worst === 'bad' ? MSG.verdictBad
        : worst === 'warn' ? MSG.verdictWarn : MSG.verdictInfo;

      const list = document.createElement('ul');
      list.className = 'findings';
      if (!findings.length) {
        const li = document.createElement('li');
        li.className = 'f-clean';
        li.textContent = MSG.msg.clean;
        list.appendChild(li);
      } else {
        findings.forEach((f) => {
          const li = document.createElement('li');
          li.className = 'f-' + f.s;
          li.textContent = MSG.msg[f.k];
          list.appendChild(li);
        });
      }
      out.appendChild(list);
      const note = document.createElement('p');
      note.className = 'disclaimer';
      note.textContent = MSG.disclaimer;
      out.appendChild(note);
    }

    btn.addEventListener('click', () => render(input.value));
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') render(input.value); });
  }
</script>
