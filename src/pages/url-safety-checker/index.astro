---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../lib/site';
import { hreflangAlternates } from '../../lib/hreflang';

const title = "URL Safety Checker - Spot Phishing Red Flags in a Link";
const description = "Free URL safety checker. Paste a suspicious link and it inspects the address for common phishing red flags - all in your browser. It cannot guarantee a site is safe, only flag warning signs.";

const alternates = hreflangAlternates('/url-safety-checker/');

const MSG = {"empty": "Paste a link to check it.", "invalid": "That does not look like a valid URL.", "verdictClean": "No common red flags in the address. Still not a safety guarantee.", "verdictInfo": "Minor things to note in this link.", "verdictWarn": "Some warning signs - be careful with this link.", "verdictBad": "Strong red flags - treat this link as suspicious.", "disclaimer": "This tool only inspects the URL text for common red flags. It cannot confirm a site is safe or malicious. When unsure, do not click.", "msg": {"notHttps": "This link uses http, not https, so traffic can be read or altered on the way.", "ipHost": "The address is a raw IP, not a domain name - common in phishing, rare for real brands.", "atSymbol": "The URL contains '@'. Everything before it is ignored by the browser - a classic trick to hide the real destination.", "punycode": "The domain uses punycode (xn--) and may display as a lookalike of a familiar name.", "manySub": "The domain has many subdomains. A brand name in a subdomain does not make it that brand.", "shortener": "This is a link shortener - the real destination is hidden until you click.", "riskyTld": "The top-level domain is one that is frequently abused. Not proof, but worth caution.", "hyphens": "The domain has several hyphens, often used to build lookalike names.", "port": "The URL uses a non-standard port, unusual for normal websites.", "encodedHost": "The host contains percent-encoded characters, sometimes used to obscure the real domain.", "longUrl": "The URL is very long, which can bury the real domain out of view.", "brandLookalike": "A well-known brand name appears in the address but not as the main domain - a common impersonation pattern.", "clean": "No common structural red flags found. This does not mean the site is safe, only that the address looks ordinary."}};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: "URL safety checker",
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any (web browser)',
    description,
    url: `${SITE.url}/url-safety-checker/`,
    inLanguage: 'en',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': `${SITE.url}/#org` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: "Home", item: SITE.url },
      { '@type': 'ListItem', position: 2, name: "URL Safety Checker", item: `${SITE.url}/url-safety-checker/` },
    ],
  },
];
---

<Base {title} {description} {schema} lang="en" {alternates} canonicalPath="/url-safety-checker/">
  <article class="prose rise mx-auto">
    <p class="mono text-xs text-ink-faint">~ / url-safety-checker</p>
    <h1 class="mt-4 font-mono text-2xl font-semibold text-ink sm:text-3xl">URL safety checker</h1>

    <p class="mt-6 text-lg text-ink-dim" set:html={"Paste a suspicious link below. This tool inspects <strong>the address itself</strong> for common phishing and malware red flags - raw IPs, lookalike brand names, punycode, risky shorteners and more. It runs <strong>entirely in your browser</strong>, never visits the link, and never sends it anywhere."}></p>

    <div id="urltool" class="urltool">
      <div class="urlrow">
        <input id="urlinput" type="text" inputmode="url" autocomplete="off" spellcheck="false" placeholder="Paste a URL, e.g. http://paypal.secure-login.example.tk/verify" />
        <button id="analyze" type="button">Check the link</button>
      </div>
      <p id="verdict" class="verdict" role="status" aria-live="polite"></p>
      <div id="results"></div>
    </div>

    <h2>What it looks for</h2>
    <p>It flags structural warning signs in the address: no HTTPS, an IP instead of a domain, an @ that hides the real destination, punycode lookalikes, deep subdomains, link shorteners, frequently-abused top-level domains, odd ports and encoded characters, and well-known brand names used outside the main domain.</p>

    <h2>The honest limits</h2>
    <p set:html={"This is a text check, not a verdict. It cannot open the page, run a scan, or query a threat database, so a clean result is <strong>not</strong> proof a site is safe, and a flag is not proof it is malicious. Treat flags as reasons to slow down. When in doubt, do not click - type the address yourself or open the official app."}></p>
    <p class="related-tool"><strong>Related tool:</strong> <a href="/file-hash-checker/">File hash checker</a></p>
  </article>
</Base>

<style>
  .urltool { margin: 26px 0; }
  .urlrow { display: flex; gap: 8px; flex-wrap: wrap; }
  .urlrow input {
    flex: 1 1 260px; min-width: 0; padding: 12px 14px; font-family: ui-monospace, monospace;
    font-size: 14px; border-radius: 10px; border: 1px solid var(--line, #33333c);
    background: rgba(255,255,255,0.02); color: inherit;
  }
  .urlrow input:focus { outline: none; border-color: #22c55e; }
  .urlrow button {
    padding: 12px 20px; border-radius: 10px; border: 1px solid #22c55e; cursor: pointer;
    background: rgba(34,197,94,0.12); color: #22c55e; font-weight: 600;
  }
  .urlrow button:hover { background: rgba(34,197,94,0.2); }
  .verdict { margin: 18px 2px 8px; font-weight: 700; min-height: 22px; }
  .v-clean { color: #22c55e; } .v-info { color: #38bdf8; } .v-warn { color: #f59e0b; } .v-bad { color: #ef4444; }
  .findings { list-style: none; padding: 0; margin: 8px 0; display: flex; flex-direction: column; gap: 8px; }
  .findings li {
    padding: 10px 12px 10px 14px; border-radius: 10px; font-size: 14px; line-height: 1.45;
    border: 1px solid var(--line, #33333c); border-left-width: 4px; background: rgba(255,255,255,0.02);
  }
  .f-bad { border-left-color: #ef4444; } .f-warn { border-left-color: #f59e0b; }
  .f-info { border-left-color: #38bdf8; } .f-clean { border-left-color: #22c55e; }
  .disclaimer { font-size: 12.5px; opacity: .7; margin-top: 14px; }
</style>


<script is:inline define:vars={{ MSG: MSG }}>
  const el = document.getElementById('urltool');
  if (el) {
    const input = document.getElementById('urlinput');
    const btn = document.getElementById('analyze');
    const out = document.getElementById('results');
    const verdict = document.getElementById('verdict');
    const SHORTENERS = ['bit.ly','tinyurl.com','goo.gl','t.co','ow.ly','is.gd','buff.ly','rebrand.ly','cutt.ly','t.ly','rb.gy','shorturl.at'];
    const RISKY_TLDS = ['zip','mov','tk','gq','ml','cf','ga','top','xyz','click','country','kim','work','loan','support','rest'];
    const BRANDS = ['paypal','apple','icloud','microsoft','office365','amazon','netflix','google','facebook','instagram','whatsapp','bank','coinbase','binance','metamask','dhl','fedex','ups','usps'];

    function analyze(raw) {
      const findings = [];
      let value = (raw || '').trim();
      if (!value) return null;
      if (!/^[a-z][a-z0-9+.-]*:\/\//i.test(value)) value = 'http://' + value;
      let u;
      try { u = new URL(value); } catch (e) { return { error: true }; }
      const host = u.hostname.toLowerCase();
      const labels = host.split('.');
      const tld = labels[labels.length - 1] || '';
      const registrable = labels.slice(-2).join('.');

      if (u.protocol === 'http:') findings.push({ s: 'warn', k: 'notHttps' });
      if (/^\d{1,3}(\.\d{1,3}){3}$/.test(host)) findings.push({ s: 'bad', k: 'ipHost' });
      if (u.username || u.password || raw.split('#')[0].split('?')[0].includes('@')) findings.push({ s: 'bad', k: 'atSymbol' });
      if (host.includes('xn--')) findings.push({ s: 'bad', k: 'punycode' });
      if (labels.length > 4) findings.push({ s: 'warn', k: 'manySub' });
      if (SHORTENERS.includes(registrable)) findings.push({ s: 'warn', k: 'shortener' });
      if (RISKY_TLDS.includes(tld)) findings.push({ s: 'warn', k: 'riskyTld' });
      if ((registrable.match(/-/g) || []).length >= 2) findings.push({ s: 'warn', k: 'hyphens' });
      if (u.port) findings.push({ s: 'warn', k: 'port' });
      if (host.includes('%')) findings.push({ s: 'bad', k: 'encodedHost' });
      if (value.length > 100) findings.push({ s: 'info', k: 'longUrl' });
      const brandHit = BRANDS.find((b) => host.includes(b));
      if (brandHit && registrable.indexOf(brandHit) !== 0) findings.push({ s: 'bad', k: 'brandLookalike' });
      return { host, findings };
    }

    function render(raw) {
      out.replaceChildren();
      verdict.textContent = '';
      verdict.className = 'verdict';
      const res = analyze(raw);
      if (!res) { verdict.textContent = MSG.empty; return; }
      if (res.error) { verdict.textContent = MSG.invalid; verdict.classList.add('v-bad'); return; }
      const findings = res.findings;
      const worst = findings.some((f) => f.s === 'bad') ? 'bad' : findings.some((f) => f.s === 'warn') ? 'warn' : findings.length ? 'info' : 'clean';
      verdict.classList.add('v-' + worst);
      verdict.textContent = worst === 'clean' ? MSG.verdictClean
        : worst === 'bad' ? MSG.verdictBad
        : worst === 'warn' ? MSG.verdictWarn : MSG.verdictInfo;

      const list = document.createElement('ul');
      list.className = 'findings';
      if (!findings.length) {
        const li = document.createElement('li');
        li.className = 'f-clean';
        li.textContent = MSG.msg.clean;
        list.appendChild(li);
      } else {
        findings.forEach((f) => {
          const li = document.createElement('li');
          li.className = 'f-' + f.s;
          li.textContent = MSG.msg[f.k];
          list.appendChild(li);
        });
      }
      out.appendChild(list);
      const note = document.createElement('p');
      note.className = 'disclaimer';
      note.textContent = MSG.disclaimer;
      out.appendChild(note);
    }

    btn.addEventListener('click', () => render(input.value));
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') render(input.value); });
  }
</script>
