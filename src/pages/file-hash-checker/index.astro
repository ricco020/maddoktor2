---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../lib/site';
import { hreflangAlternates } from '../../lib/hreflang';

const title = 'File Hash Checker - SHA-256, SHA-1 & SHA-512 in Your Browser';
const description =
  'Free file hash checker. Compute the SHA-256, SHA-1 and SHA-512 of any file to look it up in malware databases like VirusTotal. Runs entirely in your browser - the file never leaves your device.';

const alternates = hreflangAlternates('/file-hash-checker/');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'File Hash Checker',
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any (web browser)',
    description,
    url: `${SITE.url}/file-hash-checker/`,
    inLanguage: 'en',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': `${SITE.url}/#org` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'File Hash Checker', item: `${SITE.url}/file-hash-checker/` },
    ],
  },
];
---

<Base {title} {description} {schema} lang="en" {alternates} canonicalPath="/file-hash-checker/">
  <article class="prose rise mx-auto">
    <p class="mono text-xs text-ink-faint">~ / file-hash-checker</p>
    <h1 class="mt-4 font-mono text-2xl font-semibold text-ink sm:text-3xl">File hash checker</h1>

    <p class="mt-6 text-lg text-ink-dim">
      Compute the <strong>SHA-256, SHA-1 and SHA-512</strong> of any file, then paste the hash into a
      malware database such as VirusTotal to see if the file is known-bad. Everything runs
      <strong>in your browser</strong> using the built-in Web Crypto API - the file never leaves your
      device and nothing is uploaded.
    </p>

    <div
      id="hashtool"
      class="hashtool"
      data-computing="Computing hashes…"
      data-done="Done - copy a hash below"
      data-error="Could not read that file. Try another."
      data-copy="Copy"
      data-copied="Copied"
      data-nofile="Choose a file to get started"
    >
      <label class="drop" id="drop" for="fileinput">
        <input type="file" id="fileinput" hidden />
        <span class="drop-icon" aria-hidden="true">🧮</span>
        <span class="drop-main">Drop a file here or click to choose</span>
        <span class="drop-sub" id="fileinfo">Choose a file to get started</span>
      </label>

      <p class="status" id="status" role="status" aria-live="polite"></p>

      <div class="rows" id="rows" hidden>
        <div class="hrow">
          <span class="halg">SHA-256</span>
          <code class="hval" id="sha256"></code>
          <button type="button" class="copy" data-target="sha256">Copy</button>
        </div>
        <div class="hrow">
          <span class="halg">SHA-1</span>
          <code class="hval" id="sha1"></code>
          <button type="button" class="copy" data-target="sha1">Copy</button>
        </div>
        <div class="hrow">
          <span class="halg">SHA-512</span>
          <code class="hval" id="sha512"></code>
          <button type="button" class="copy" data-target="sha512">Copy</button>
        </div>
      </div>
    </div>

    <h2>How to use it to check a suspicious file</h2>
    <ol>
      <li>Select the file above. Its hashes appear instantly.</li>
      <li>Copy the <strong>SHA-256</strong> value.</li>
      <li>
        Paste it into a reputation service - for example the search box at
        <a href="https://www.virustotal.com/" rel="nofollow noopener" target="_blank">VirusTotal</a>.
        If the file is known malware, the database recognises the hash.
      </li>
    </ol>

    <h2>Why a hash helps</h2>
    <p>
      A hash is a short fingerprint of a file. Change one byte and the hash changes completely. Threat
      databases store the hashes of known malware, so checking a hash tells you whether a file matches a
      sample that has already been analysed - without uploading your file anywhere.
    </p>

    <h2>The honest limits</h2>
    <p>
      A hash lookup only recognises <em>known</em> samples. A brand-new or slightly altered malware file
      will have a hash nobody has seen yet, so a clean result is <strong>not</strong> a guarantee the
      file is safe. Use this as one signal alongside a real anti-malware scan. We do not offer MD5 here:
      it is cryptographically broken, and SHA-256 is the value modern databases prefer.
    </p>
    <p class="related-tool"><strong>Related tool:</strong> <a href="/url-safety-checker/">URL safety checker</a></p>
  </article>
</Base>

<style>
  .hashtool { margin: 28px 0; }
  .drop {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; text-align: center; padding: 34px 18px; cursor: pointer;
    border: 2px dashed var(--line, #3a3a44); border-radius: 14px;
    background: rgba(255,255,255,0.02); transition: border-color .15s, background .15s;
  }
  .drop:hover, .drop.over { border-color: #22c55e; background: rgba(34,197,94,0.06); }
  .drop-icon { font-size: 30px; }
  .drop-main { font-weight: 600; }
  .drop-sub { font-size: 13px; opacity: .7; word-break: break-all; }
  .status { min-height: 20px; font-size: 14px; opacity: .85; margin: 12px 2px; }
  .rows { display: flex; flex-direction: column; gap: 10px; }
  .hrow {
    display: grid; grid-template-columns: 84px 1fr auto; align-items: center; gap: 10px;
    padding: 10px 12px; border: 1px solid var(--line, #33333c); border-radius: 10px;
    background: rgba(255,255,255,0.02);
  }
  .halg { font-family: ui-monospace, monospace; font-size: 12px; font-weight: 700; color: #22c55e; }
  .hval { font-family: ui-monospace, monospace; font-size: 12.5px; word-break: break-all; }
  .copy {
    font-size: 12px; padding: 5px 12px; border-radius: 8px; cursor: pointer;
    border: 1px solid var(--line, #3a3a44); background: transparent; color: inherit;
  }
  .copy:hover { border-color: #22c55e; color: #22c55e; }
  @media (max-width: 560px) { .hrow { grid-template-columns: 1fr; } }
</style>

<script>
  const el = document.getElementById('hashtool');
  if (el) {
    const d = el.dataset;
    const input = document.getElementById('fileinput');
    const drop = document.getElementById('drop');
    const status = document.getElementById('status');
    const rows = document.getElementById('rows');
    const info = document.getElementById('fileinfo');
    const algos = { 'SHA-256': 'sha256', 'SHA-1': 'sha1', 'SHA-512': 'sha512' };

    const toHex = (buf) =>
      Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, '0')).join('');

    const fmtSize = (n) => {
      if (n < 1024) return n + ' B';
      if (n < 1048576) return (n / 1024).toFixed(1) + ' KB';
      if (n < 1073741824) return (n / 1048576).toFixed(1) + ' MB';
      return (n / 1073741824).toFixed(2) + ' GB';
    };

    async function run(file) {
      if (!file) return;
      info.textContent = file.name + ' (' + fmtSize(file.size) + ')';
      status.textContent = d.computing;
      rows.hidden = true;
      try {
        const buf = await file.arrayBuffer();
        for (const [alg, id] of Object.entries(algos)) {
          const digest = await crypto.subtle.digest(alg, buf);
          document.getElementById(id).textContent = toHex(digest);
        }
        rows.hidden = false;
        status.textContent = d.done;
      } catch (e) {
        status.textContent = d.error;
      }
    }

    input.addEventListener('change', () => run(input.files[0]));
    ['dragenter', 'dragover'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); })
    );
    ['dragleave', 'drop'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); })
    );
    drop.addEventListener('drop', (e) => {
      const f = e.dataTransfer && e.dataTransfer.files[0];
      if (f) run(f);
    });

    document.querySelectorAll('.copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const val = document.getElementById(btn.dataset.target).textContent;
        if (!val) return;
        try {
          await navigator.clipboard.writeText(val);
          const old = btn.textContent;
          btn.textContent = d.copied;
          setTimeout(() => { btn.textContent = old; }, 1200);
        } catch (e) {}
      });
    });
  }
</script>
