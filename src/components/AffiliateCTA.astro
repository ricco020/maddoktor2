---
interface Props {
  href: string;
  product: string;
  blurb: string;
}
const { href, product, blurb } = Astro.props;
---

<aside class="not-prose my-8 border border-edge bg-bg p-5" style="border-radius:10px;border-left:4px solid var(--bar)">
  <p class="mono text-xs tracking-wide uppercase" style="color:var(--bar);font-weight:700">Rx · recommended · affiliate link</p>
  <p class="mt-2 text-ink" style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:17px;letter-spacing:-.2px">{blurb}</p>
  <a
    href={href}
    rel="sponsored nofollow noopener noreferrer"
    class="mt-3 inline-block px-4 py-2 text-sm font-semibold text-void no-underline transition-colors"
    style="border-radius:7px;background:var(--bar);font-family:'Space Grotesk',sans-serif"
    onmouseover="this.style.background='var(--bar-d)'" onmouseout="this.style.background='var(--bar)'"
  >
    Get {product} →
  </a>
</aside>
